" custom.vim

set wildmenu
set wildmenu wildoptions=pum
set backspace=indent,eol,start
set nowrap

set number
set relativenumber

set signcolumn=no
set guicursor=
set termguicolors
set tabstop=4
set softtabstop=4
set shiftwidth=4
set expandtab
set smartindent
set hlsearch
set incsearch
set nobackup
set noswapfile
let &undodir = expand("$HOME") . "/.vim/undodir"
set undofile
set updatetime=50
set mouse=
let g:netrw_banner = 0
set scrolloff=8

set laststatus=0

